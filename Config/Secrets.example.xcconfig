// Скопируй этот файл в Config/Secrets.xcconfig (он в .gitignore) и заполни значения.
// Реальные значения — из kolco24_app_v2/local.properties (kolco24.apiBaseUrl / kolco24.appKeyId / kolco24.appSecret).
//
// Гоча: `//` в URL — начало комментария в xcconfig, поэтому нужен трюк `$()`:
//   https:/$()/example.com  ->  https://example.com
// Сломанный трюк обрежет значение до "https:" — это ловит проверка url.host в SecretsTests.

API_BASE_URL = https:/$()/api.example.com
APP_KEY_ID = your-app-key-id
APP_SECRET = your-hex-secret
LOCAL_API_BASE_URL = http:/$()/192.168.1.5
